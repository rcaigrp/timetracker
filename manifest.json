{
  "manifest_version": 3,
  "name": "LocalTrack",
  "version": "1.0.0",
  "description": "Privacy-first local-only time tracking extension",
  "permissions": [
    "storage",
    "tabs"
  ],
  "action": {
    "default_popup": "index.html",
    "default_title": "LocalTrack"
  },
  "background": {
    "service_worker": "background.js"
  }
}